WARPARTY_PUBLIC_BASE_URL=http://localhost:8080
WARPARTY_DATABASE_PATH=./App_Data/warparty.db
WARPARTY_DATA_DIR=./App_Data
WARPARTY_MAX_PLAYERS_PER_PARTY=4
WARPARTY_IMAGE_TTL_MINUTES=60
WARPARTY_MAX_UPLOAD_BYTES=10485760
# Optional. If omitted, Warparty creates a persistent secret at WARPARTY_SECRET_KEY_FILE.
# WARPARTY_SECRET_KEY=change-this-local-secret
WARPARTY_SECRET_KEY_FILE=./App_Data/secret_key
WARPARTY_COOKIE_SECURE=false
WARPARTY_ALLOWED_HOSTS=*
WARPARTY_LOG_LEVEL=info
WARPARTY_PORT=8080
WARPARTY_SQLITE_BUSY_TIMEOUT_MS=5000
WARPARTY_SQLITE_WAL=true
WARPARTY_STALE_PLAYER_MINUTES=60
# Copies old /app/App_Data database/secret files into the configured data path if
# the new files are missing. Disable only after legacy upgrades are complete.
WARPARTY_AUTO_MIGRATE_LEGACY_DATA=true
WARPARTY_LEGACY_DATA_DIR=/app/App_Data
WARPARTY_ENV=development
